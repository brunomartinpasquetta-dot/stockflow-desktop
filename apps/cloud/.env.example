# --- Entorno ---
NODE_ENV=development
PORT=3009
HOST=0.0.0.0

# --- Base de datos (Postgres) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stockflow_cloud

# --- JWT (RS256) ---
# Opcional: si se setean, se usan estas claves (con \n escapados). Si no, se leen
# de apps/cloud/.keys/*.pem o se generan automáticamente al arrancar.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- MercadoPago ---
# Token de acceso (en pruebas empieza con TEST-...). Si está vacío, el alta de
# clientes igual funciona (queda pendiente y se contacta manualmente).
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
# Secreto para validar la firma del webhook (panel de developers de MP).
MP_WEBHOOK_SECRET=

# --- SMTP (emails transaccionales) ---
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=StockFlow <no-reply@stockflow.local>

# --- Panel de administración ---
ADMIN_EMAIL=admin@stockflow.local
# Hash bcrypt de la contraseña del admin. Generar con:
#   node -e "console.log(require('bcryptjs').hashSync('TU_PASSWORD', 10))"
ADMIN_PASSWORD_HASH=

# --- URLs públicas ---
BASE_URL=http://localhost:3009
LANDING_URL=http://localhost:3009/landing.html

# --- Precios de los planes (ARS / mes) ---
PLAN_BASIC_PRICE=15000
PLAN_PRO_PRICE=25000

# --- CORS ---
# Lista de orígenes permitidos, separados por coma. Si está vacío, se permite cualquiera.
CORS_ORIGINS=
