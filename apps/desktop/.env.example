# --- Cliente de licencias (StockFlow Cloud) ---
#
# Estas variables las lee el PROCESO MAIN de Electron en tiempo de ejecución
# (process.env.CLOUD_API_URL / process.env.CLOUD_JWT_PUBLIC_KEY). El script de
# build/launch es responsable de exportarlas al entorno del proceso.

# URL base del servidor de licencias (apps/cloud). En dev, localhost.
CLOUD_API_URL=http://localhost:3009

# Clave pública RS256 (PEM) embebida en el build para validar OFFLINE el JWT de
# licencia. En desarrollo se puede dejar vacía: el desktop confiará en el JWT sin
# verificar la firma (ver LicenseManager.verifyJwtOffline). En producción es
# obligatoria. Pegar el PEM en una sola línea con "\n" o como variable multilínea
# según lo soporte tu launcher.
CLOUD_JWT_PUBLIC_KEY=
